// AssetFlow Prisma schema
// Core models (Department, User, AssetCategory, Asset) — issue #4.
// Transactional models (allocations, transfers, bookings, maintenance, audits,
// notifications, activity log) — issue #5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  UNDER_MAINTENANCE
  RETIRED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  headId String? @unique
  head   User?   @relation("DepartmentHead", fields: [headId], references: [id])

  members     User[]       @relation("DepartmentMembers")
  assets      Asset[]
  auditCycles AuditCycle[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])

  headOfDepartment Department? @relation("DepartmentHead")

  allocationsHeld      Allocation[]         @relation("AllocationHolder")
  allocationsGranted   Allocation[]         @relation("AllocationAllocatedBy")
  transfersFrom        TransferRequest[]    @relation("TransferFromUser")
  transfersTo          TransferRequest[]    @relation("TransferToUser")
  transfersRequested   TransferRequest[]    @relation("TransferRequestedBy")
  transfersApproved    TransferRequest[]    @relation("TransferApprovedBy")
  bookings             Booking[]
  maintenanceRequested MaintenanceRequest[] @relation("MaintenanceRequestedBy")
  maintenanceApproved  MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  auditCyclesCreated   AuditCycle[]         @relation("AuditCycleCreatedBy")
  auditAssignments     AuditAssignment[]    @relation("AuditAssignmentAuditor")
  auditRecordsVerified AuditRecord[]        @relation("AuditRecordVerifiedBy")
  notifications        Notification[]
  activityLogs         ActivityLog[]

  @@index([departmentId])
}

model AssetCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  extraFields Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]
}

model Asset {
  id           String         @id @default(cuid())
  assetTag     String         @unique
  name         String
  status       AssetStatus    @default(AVAILABLE)
  condition    AssetCondition @default(GOOD)
  isBookable   Boolean        @default(false)
  serialNumber String?
  purchaseDate DateTime?
  purchaseCost Decimal?       @db.Decimal(12, 2)
  location     String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  allocations         Allocation[]
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditRecords        AuditRecord[]

  @@index([categoryId])
  @@index([departmentId])
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

model Allocation {
  id                    String           @id @default(cuid())
  status                AllocationStatus @default(ACTIVE)
  allocatedAt           DateTime         @default(now())
  dueDate               DateTime?
  returnedAt            DateTime?
  conditionAtAllocation AssetCondition
  conditionAtReturn     AssetCondition?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  holderId String
  holder   User   @relation("AllocationHolder", fields: [holderId], references: [id])

  allocatedById String
  allocatedBy   User   @relation("AllocationAllocatedBy", fields: [allocatedById], references: [id])

  @@index([assetId])
  @@index([holderId])
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

model TransferRequest {
  id          String         @id @default(cuid())
  status      TransferStatus @default(REQUESTED)
  reason      String?
  requestedAt DateTime       @default(now())
  approvedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  fromUserId String?
  fromUser   User?   @relation("TransferFromUser", fields: [fromUserId], references: [id])

  toUserId String
  toUser   User   @relation("TransferToUser", fields: [toUserId], references: [id])

  requestedById String
  requestedBy   User   @relation("TransferRequestedBy", fields: [requestedById], references: [id])

  approvedById String?
  approvedBy   User?   @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  @@index([assetId])
  @@index([toUserId])
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

model Booking {
  id        String        @id @default(cuid())
  status    BookingStatus @default(CONFIRMED)
  startTime DateTime
  endTime   DateTime
  purpose   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  bookedById String
  bookedBy   User   @relation(fields: [bookedById], references: [id])

  @@index([assetId, startTime, endTime])
}

enum MaintenanceStatus {
  REQUESTED
  APPROVED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model MaintenanceRequest {
  id               String            @id @default(cuid())
  status           MaintenanceStatus @default(REQUESTED)
  issueDescription String
  cost             Decimal?          @db.Decimal(12, 2)
  notes            String?
  requestedAt      DateTime          @default(now())
  approvedAt       DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  requestedById String
  requestedBy   User   @relation("MaintenanceRequestedBy", fields: [requestedById], references: [id])

  approvedById String?
  approvedBy   User?   @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])

  @@index([assetId])
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

model AuditCycle {
  id        String           @id @default(cuid())
  name      String
  status    AuditCycleStatus @default(OPEN)
  startDate DateTime         @default(now())
  closedAt  DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  createdById String
  createdBy   User   @relation("AuditCycleCreatedBy", fields: [createdById], references: [id])

  assignments AuditAssignment[]
  records     AuditRecord[]

  @@index([departmentId])
}

model AuditAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  auditorId String
  auditor   User   @relation("AuditAssignmentAuditor", fields: [auditorId], references: [id])

  @@unique([auditCycleId, auditorId])
}

model AuditRecord {
  id               String         @id @default(cuid())
  verifiedAt       DateTime       @default(now())
  foundStatus      AssetStatus
  foundCondition   AssetCondition
  isDiscrepant     Boolean        @default(false)
  discrepancyNotes String?
  createdAt        DateTime       @default(now())

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  verifiedById String
  verifiedBy   User   @relation("AuditRecordVerifiedBy", fields: [verifiedById], references: [id])

  @@unique([auditCycleId, assetId])
  @@index([assetId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  relatedEntityType String?
  relatedEntityId   String?

  @@index([userId, isRead])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}
